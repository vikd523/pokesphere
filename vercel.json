{
    "rewrites": [
        {
            "source": "/api/tcgprices",
            "destination": "/api/tcgprices/index.ts"
        },
        {
            "source": "/api/pokemontcg/(.*)",
            "destination": "/api/pokemontcg/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}